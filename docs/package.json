{
  "name": "zudoku-docs-portal",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "bundle": "redocly bundle v1/openapi.yaml -o .bundled/v1.yaml --dereferenced && redocly bundle organizers/openapi.yaml -o .bundled/organizers.yaml --dereferenced",
    "dev": "npm run bundle && zudoku dev",
    "build": "npm run bundle && zudoku build",
    "preview": "zudoku preview",
    "lint": "eslint"
  },
  "dependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zudoku": "0.71.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.21.0"
  }
}
